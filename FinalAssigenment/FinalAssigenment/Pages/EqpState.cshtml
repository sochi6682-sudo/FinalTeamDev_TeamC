@page
@model FinalAssigenment.Pages.EqpStateModel
@{
    ViewData["Title"] = "設備状態";
}

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="manifest" href="/manifest.json" />
    <link rel="stylesheet" href="/css/site.css" />

    <title>設備状態画面</title>
</head>

<body>

    <!-- サーバー停止オーバーレイ -->
    <div id="serverStopOverlay" class="card-img-overlay hidden">
        <div class="overlay-text">サーバー停止中</div>
    </div>

    <!-- 設備状態画面 -->
    <div id="screen-shelf-status" class="modal-fullscreen hidden">
        <h2>設備状態</h2>

        <div id="equipment-status"></div>

        <button id="btn-back">戻る</button>
    </div>

    <script src="js/site.js"></script>
</body>