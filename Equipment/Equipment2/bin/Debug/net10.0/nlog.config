<?xml version="1.0" encoding="utf-8" ?>

<nlog xmlns="http://nlog-project.org"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

	<targets>

		<target xsi:type="File"
				name="logfile"
				fileName="logs/Equipment2_${shortdate}.log"
				layout="${date:format=yyyy-MM-dd HH\:mm\:ss} [${level:capitalize=true}] ${message}" />

	</targets>

	<rules>

		<logger name="*"
				minlevel="Info"
				writeTo="logfile" />

	</rules>

</nlog>