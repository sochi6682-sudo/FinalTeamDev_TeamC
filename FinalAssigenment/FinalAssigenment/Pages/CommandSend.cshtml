@page
@model FinalAssigenment.Pages.CommandSendModel
@{
    ViewData["Title"] = "搬送指示送信";
}

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="manifest" href="/manifest.json" />
    <link rel="stylesheet" href="/css/site.css" />

    <title>搬送指示送信画面</title>
</head>

<body>

    <!-- サーバー停止オーバーレイ -->
    <div id="serverStopOverlay" class="card-img-overlay hidden">
        <div class="overlay-text">サーバー停止中</div>
    </div>

    <!-- 搬送指示送信画面 -->
    <div id="screen-send-comand" class="modal-fullscreen hidden">
        <h2>搬送指示送信</h2>

        キャリアID:<input id="input-carrier" type="text"><br>
        自動保管棚ID:
        <select id="input-shelf"></select>

        <button id="btn-inbound">入庫</button>
        <button id="btn-outbound">出庫</button>

        <span class="lamp-inbound" data-id="10101"></span>
        <span class="lamp-outbound" data-id="10101"></span>

        <button id="btn-back">戻る</button>
    </div>

    <script src="js/site.js"></script>
</body>