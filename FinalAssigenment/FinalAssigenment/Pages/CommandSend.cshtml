@page
@model FinalAssigenment.Pages.CommandSendModel
@{
    ViewData["Title"] = "搬送指示送信";
}

<div id="page-command-send" class="page-container">

    <h1>搬送指示送信</h1>

    <div class="form-section">

        <label>キャリアID</label>
        <select id="carrierIdSelect" class="input-field">
            <option value="">選択してください</option>
        </select>

        <label>棚ID</label>
        <select id="shelfIdSelect" class="input-field" disabled>
            <option value="">自動選択</option>
        </select>

        <label>結果表示</label>
        <div id="resultArea" class="result-box"></div>

        <div class="button-row">
            <button id="btn-inbound" class="send-button">入庫</button>
            <button id="btn-outbound" class="send-button">出庫</button>
        </div>
    </div>

    <h2>設備状態（簡易）</h2>
    <div id="command-equip-status"></div>

</div>

